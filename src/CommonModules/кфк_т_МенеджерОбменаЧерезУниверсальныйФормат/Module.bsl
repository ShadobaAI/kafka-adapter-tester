Процедура ЗаполнитьПравилаКонвертацииПредопределенныхДанных(НаправлениеОбмена, ПравилаКонвертации) Экспорт

	// Перечисление_ТестовоеПеречисление.
	ПравилоКонвертации           = ПравилаКонвертации.Добавить();
	ПравилоКонвертации.ИмяПКПД   = "Перечисление_ТестовоеПеречисление";
	ПравилоКонвертации.ТипДанных = Метаданные.Перечисления.кфк_т_ТестовоеПеречисление;
	ПравилоКонвертации.ТипXDTO   = "TestCatalog.Enum";

	ЗначенияДляОтправки = Новый Соответствие;
	ЗначенияДляОтправки.Вставить(Перечисления.кфк_т_ТестовоеПеречисление.Значение1, "Значение1");
	ЗначенияДляОтправки.Вставить(Перечисления.кфк_т_ТестовоеПеречисление.Значение2, "Значение2");
	ЗначенияДляОтправки.Вставить(Перечисления.кфк_т_ТестовоеПеречисление.Значение3, "Значение3");
	ПравилоКонвертации.КонвертацииЗначенийПриОтправке = ЗначенияДляОтправки;
	ЗначенияДляПолучения = Новый Соответствие;
	ЗначенияДляПолучения.Вставить("Значение1", Перечисления.кфк_т_ТестовоеПеречисление.Значение1);
	ЗначенияДляПолучения.Вставить("Значение2", Перечисления.кфк_т_ТестовоеПеречисление.Значение2);
	ЗначенияДляПолучения.Вставить("Значение3", Перечисления.кфк_т_ТестовоеПеречисление.Значение3);
	ПравилоКонвертации.КонвертацииЗначенийПриПолучении = ЗначенияДляПолучения;

КонецПроцедуры
